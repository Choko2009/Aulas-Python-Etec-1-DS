import funções
funções.limpar_tela()

print("Manipulando funções com python!")
resposta="SIM"
while(resposta=="SIM"):

    funções.exibir_menu()

    opção=int(input("escolha uma das opções: "))

    num1=float(input("digite o prmeiro numero: "))
    num2=float(input("digite o segundo numero: "))

    if(opção==1):
        total = funções.somar(num1,num2)
        print(f" a soma é: {total}")
    elif(opção==2):
        total=funções.subtrair(num1,num2)
        print(f"a subtração é: {total}")
    elif(opção==3):
        print(f"a multiplicação é: {funções.multiplicar(num1,num2)}")
    elif(opção==4):
        print(f"a divisão é: {funções.dividir(num1,num2)}")
    else:
        print("opção invalida.")

    resposta=input("deseja executar novamente? (sim ou não): ").upper()

